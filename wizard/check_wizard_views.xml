<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_trueformat_check_wizard_form" model="ir.ui.view">
        <field name="name">trueformat.check.wizard.form</field>
        <field name="model">trueformat.check.wizard</field>
        <field name="arch" type="xml">
            <form string="TrueFormat CSV Integrity Check">
                <sheet>
                    <div class="text-muted mb-2">
                        Attach one or more CSV files. Each file is checked in-memory.
                        Nothing is stored. Limits: .csv files up to 20 MB / 250,000 rows.
                    </div>
                    <div class="alert alert-info" role="alert">
                        Requires a TrueFormat API key in
                        Settings → Technical → Parameters → System Parameters
                        (<code>trueformat.api_key</code>).
                    </div>

                    <div class="alert alert-success mt-2" role="alert" invisible="not batch_summary">
                        <field name="batch_summary" nolabel="1" readonly="1"/>
                    </div>

                    <field name="line_ids" nolabel="1">
                        <list editable="bottom" create="1" delete="1">
                            <field name="sequence" widget="handle"/>
                            <field name="csv_file" widget="binary" filename="csv_filename" string="File"/>
                            <field name="csv_filename" column_invisible="1"/>
                            <field name="state" widget="badge"
                                   decoration-success="state in ('checked', 'fixed') and issues_found == 0"
                                   decoration-warning="state in ('checked', 'fixed') and issues_found &gt; 0"
                                   decoration-danger="state == 'error'"
                                   decoration-muted="state == 'pending'"/>
                            <field name="issues_found" string="Issues"/>
                            <field name="row_count" string="Rows"/>
                            <field name="error_message" string="Error" optional="show"
                                   invisible="state != 'error'"/>
                            <button name="action_check" type="object" string="Check"
                                    icon="fa-search"
                                    invisible="state not in ('pending', 'error')"/>
                            <button name="action_fix" type="object" string="Fix"
                                    icon="fa-wrench"
                                    invisible="state != 'checked' or issues_found == 0"/>
                            <button name="action_show_detail" type="object" string="Preview"
                                    icon="fa-eye"
                                    invisible="state not in ('checked', 'fixed', 'error')"/>
                        </list>
                    </field>

                    <separator string="File Detail" invisible="not selected_line_id"/>

                    <group invisible="not selected_line_id">
                        <field name="selected_line_id" invisible="1"/>
                        <field name="selected_csv_filename" string="File" readonly="1"/>
                        <field name="selected_state" string="Status" widget="badge" readonly="1"/>
                    </group>

                    <div class="alert alert-danger mt-2" role="alert"
                         invisible="not selected_error_message">
                        <field name="selected_error_message" nolabel="1" readonly="1"/>
                    </div>

                    <div invisible="selected_state not in ('checked', 'fixed')">
                        <field name="issues_found" invisible="1"/>
                        <field name="row_count" invisible="1"/>
                        <field name="result_summary" invisible="1"/>
                        <field name="preview_data" widget="trueformat_preview" nolabel="1"/>

                        <group string="Detection report" invisible="not result_detail" class="mt-3">
                            <field name="result_detail" nolabel="1" readonly="1"
                                   widget="text"
                                   class="o_trueformat_result_detail"/>
                        </group>

                        <group invisible="not fixed_file" class="mt-3">
                            <field name="fixed_file" filename="fixed_filename" readonly="1"/>
                            <field name="fixed_filename" invisible="1"/>
                        </group>
                        <div invisible="not fixed_file" class="text-muted">
                            Download the corrected file above. Fix All Columns
                            repairs the whole CSV (every row): scientific
                            notation, Excel date serials, date-coerced SKUs
                            (SEP-26 → TF-serial), quotes/semicolons, and
                            leading zeros where recoverable. Reconstructed
                            values (TF-*) still need verification at source.
                        </div>
                    </div>
                </sheet>

                <footer>
                    <button name="action_check_all" string="Save" type="object"
                            class="btn-primary" invisible="not line_ids"/>
                    <button name="action_fix_selected" string="Fix All Columns" type="object"
                            class="btn-primary"
                            invisible="selected_state != 'checked' or issues_found == 0"/>
                    <button name="action_reset" string="Start Over" type="object"
                            class="btn-secondary" invisible="not line_ids"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_trueformat_check_wizard" model="ir.actions.act_window">
        <field name="name">CSV Integrity Check</field>
        <field name="res_model">trueformat.check.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
